# Public API base URL for the Express backend (used once API integration replaces local mock data)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Google OAuth (client-side, if/when wired to real NextAuth or custom OAuth flow)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudinary (if uploading directly from the client via unsigned preset)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
